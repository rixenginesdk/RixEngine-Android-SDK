            android:label="Alx Ad: banner"/>
        <activity android:name="com.alxad.sdk.demo.alx.RewardVideoActivity"
            android:label="Alx Ad: reward video"/>
        <activity android:name="com.alxad.sdk.demo.alx.InterstitialVideoActivity"
            android:label="Alx Ad: interstitial Ad - video"/>
        <activity android:name="com.alxad.sdk.demo.alx.InterstitialBannerActivity"
            android:label="Alx Ad: interstitial Ad - banner"/>
        <activity
            android:name="com.alxad.sdk.demo.alx.NativeActivity"
            android:label="Alx Ad: native" />
        <!-- Alx demo：end -->

        <!-- TopOn平台 demo案例 -->
        <activity
            android:name="com.alxad.sdk.demo.topon.TopOnDemoListActivity"
            android:label="TopOn Ad" />
        <activity android:name="com.alxad.sdk.demo.topon.TopOnBannerActivity"
            android:label="TopOn Ad: banner"/>
        <activity android:name="com.alxad.sdk.demo.topon.TopOnNativeActivity"
            android:label="TopOn Ad: native"/>
        <activity android:name="com.alxad.sdk.demo.topon.TopOnRewardVideoActivity"
            android:label="TopOn Ad: reward video"/>
        <activity android:name="com.alxad.sdk.demo.topon.TopOnInterstitialActivity"
            android:label="TopOn Ad: interstitial"/>
        <activity android:name="com.alxad.sdk.demo.topon.TopOnSplashActivity"
            android:label="TopOn Ad: splash"/>

        <!-- Admob平台 demo案例 -->
        <activity
            android:name="com.alxad.sdk.demo.admob.AdmobDemoListActivity"
            android:label="Admob Ad" />
        <activity android:name="com.alxad.sdk.demo.admob.AdmobBannerActivity"
            android:label="Admob Ad: banner"/>
        <activity android:name="com.alxad.sdk.demo.admob.AdmobRewardVideoActivity"
            android:label="Admob Ad: reward video"/>
        <activity android:name="com.alxad.sdk.demo.admob.AdmobInterstitialActivity"
            android:label="Admob Ad: interstitial"/>
        <activity android:name="com.alxad.sdk.demo.admob.AdmobNativeActivity"
            android:label="Admob Ad: native"/>


