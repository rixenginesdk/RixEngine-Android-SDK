        <activity
            android:name="com.alxad.sdk.demo.max.MaxInterstitialActivity"
            android:label="max Ad:interstitial" />
        <activity
            android:name="com.alxad.sdk.demo.max.MaxRewardVideoActivity"
            android:label="max Ad:reward video" />
        <activity
            android:name="com.alxad.sdk.demo.max.MaxNativeActivity"
            android:label="max Ad:native" />


        <!-- 下面是配置信息 -->
        <!--Admob平台——start -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-4920936244266233~6784498952"/>
        <!--Admob平台——end -->

        <!--TopOn平台——start -->
        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />
        <!--google-->
        <meta-data
            android:name="com.google.android.gms.ads.AD_MANAGER_APP"
            android:value="true" />
        <!--TopOn平台——end -->


        <!--LevelPlay(原 IronSource)平台——start -->
        <provider
            android:name="com.ironsource.lifecycle.IronsourceLifecycleProvider"
            android:authorities="${applicationId}.IronsourceLifecycleProvider" />
        <!--LevelPlay(原 IronSource)平台——end -->

    </application>


</manifest>