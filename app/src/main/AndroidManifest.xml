        <activity
            android:name="com.alxad.sdk.demo.gam.GamDemoListActivity"
            android:label="Gam Ad" />
        <activity android:name="com.alxad.sdk.demo.gam.GamBannerActivity"
            android:label="Gam Ad: banner"/>
        <activity android:name="com.alxad.sdk.demo.gam.GamRewardVideoActivity"
